{
  "$schema": "https://design-tokens.org/v1",
  "version": "1.0.0",
  "brand": "akong",
  "subject": "杭州阿空智能科技有限公司",
  "style": "shadcn",
  "style_note": "shadcn 极客风 · 黑白灰为主 · 单一 primary · 圆角小 · 阴影微妙 · 系统字体 · light + dark 两套 (老板 5-6 拍)",

  "color_hsl": {
    "_doc": "shadcn 标准 · HSL 字符串 · CSS variables 模式 · 各仓直接 var(--<name>) 引用",
    "light": {
      "background":          "0 0% 100%",
      "foreground":          "0 0% 3.9%",
      "card":                "0 0% 100%",
      "card-foreground":     "0 0% 3.9%",
      "popover":             "0 0% 100%",
      "popover-foreground":  "0 0% 3.9%",
      "primary":             "0 0% 9%",
      "primary-foreground":  "0 0% 98%",
      "secondary":           "0 0% 96.1%",
      "secondary-foreground":"0 0% 9%",
      "muted":               "0 0% 96.1%",
      "muted-foreground":    "0 0% 45.1%",
      "accent":              "0 0% 96.1%",
      "accent-foreground":   "0 0% 9%",
      "destructive":         "0 84.2% 60.2%",
      "destructive-foreground":"0 0% 98%",
      "border":              "0 0% 89.8%",
      "input":               "0 0% 89.8%",
      "ring":                "0 0% 3.9%"
    },
    "dark": {
      "background":          "0 0% 3.9%",
      "foreground":          "0 0% 98%",
      "card":                "0 0% 3.9%",
      "card-foreground":     "0 0% 98%",
      "popover":             "0 0% 3.9%",
      "popover-foreground":  "0 0% 98%",
      "primary":             "0 0% 98%",
      "primary-foreground":  "0 0% 9%",
      "secondary":           "0 0% 14.9%",
      "secondary-foreground":"0 0% 98%",
      "muted":               "0 0% 14.9%",
      "muted-foreground":    "0 0% 63.9%",
      "accent":              "0 0% 14.9%",
      "accent-foreground":   "0 0% 98%",
      "destructive":         "0 62.8% 30.6%",
      "destructive-foreground":"0 0% 98%",
      "border":              "0 0% 14.9%",
      "input":               "0 0% 14.9%",
      "ring":                "0 0% 83.1%"
    }
  },

  "font": {
    "family": {
      "sans": ["Geist", "system-ui", "-apple-system", "PingFang SC", "Hiragino Sans GB", "sans-serif"],
      "mono": ["Geist Mono", "ui-monospace", "SF Mono", "Cascadia Code", "monospace"]
    },
    "size": {
      "xs":   "0.75rem",
      "sm":   "0.875rem",
      "base": "1rem",
      "lg":   "1.125rem",
      "xl":   "1.25rem",
      "2xl":  "1.5rem",
      "3xl":  "1.875rem",
      "4xl":  "2.25rem"
    },
    "weight": {
      "normal":   400,
      "medium":   500,
      "semibold": 600,
      "bold":     700
    }
  },

  "spacing": {
    "0":  "0",
    "1":  "0.25rem",
    "2":  "0.5rem",
    "3":  "0.75rem",
    "4":  "1rem",
    "6":  "1.5rem",
    "8":  "2rem",
    "12": "3rem",
    "16": "4rem"
  },

  "radius": {
    "sm":   "calc(var(--radius) - 4px)",
    "md":   "calc(var(--radius) - 2px)",
    "lg":   "var(--radius)",
    "full": "9999px",
    "default": "0.5rem",
    "_doc": "shadcn 风 default 0.5rem · 偏小偏极客 · 跟之前 16px lg 比明显方"
  },

  "icp": {
    "filed": true,
    "number": "浙ICP备2026022274号",
    "footer": "杭州阿空智能科技有限公司 · 浙ICP备2026022274号"
  },

  "_deprecated_v0": {
    "_doc": "v0.x 旧 tokens · 各仓尚在引用 · 不立刻删 · 后续迁完移除",
    "color": {
      "ink":     "#1a1a1a",
      "paper":   "#fafafa",
      "muted":   "#6b6b6b",
      "border":  "#e5e7eb",
      "accent":  "#7c5cff",
      "agent": {
        "xiaoxi":   "#ec4899",
        "xiaoqiao": "#ff7a3d",
        "xiaoyan":  "#7c5cff",
        "dayan":    "#8b5cf6",
        "xiaohua":  "#14b8a6",
        "xiaozhi":  "#6366f1",
        "xiaoke":   "#06b6d4",
        "fitness":  "#10b981",
        "ppt":      "#f59e0b",
        "akong":    "#000000"
      },
      "feedback": {
        "success": "#10b981",
        "warning": "#f59e0b",
        "danger":  "#ef4444",
        "info":    "#3b82f6"
      }
    }
  }
}
